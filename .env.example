# Copy to .env and fill in. NEVER commit a real .env (see .gitignore).
# Env vars grow per phase (HANDOFF §5); this is the Milestone-0 minimum.

# --- LM Studio model endpoint (Milestone 0) ---
# Host-only for now (running `adk web` directly on the host). INVARIANT #4: once the control
# plane is containerized (Milestone 1+), set this to the LM Studio host's LAN IP, NEVER
# localhost — inside a container, localhost is the container itself, not the model host.
LMSTUDIO_API_BASE=http://127.0.0.1:1234/v1

# Default worker model — used by everything EXCEPT the coding agent (triage / QA / team-lead / the
# current general worker). Pick a strong function-calling instruct model; the backbone leans on
# tool-calling quality. If it's a reasoning model, suppress thinking on QA + team-lead (invariant
# #15). A weak model (e.g. a 4B) tends to loop tools without finishing — use a capable one.
LMSTUDIO_MODEL=ministral-3-14b-reasoning-2512

# The coding agent (Phase 9) uses a code-specialized model instead — set here so the policy is
# recorded now; build_model() already accepts a per-agent override, so no code change is needed.
LMSTUDIO_CODING_MODEL=devstral-small-2-24b-instruct-2512

# --- Workload sandbox / exec service (Milestone 1) ---
# Shared bearer token: only the control plane holds it, so only it can drive the exec service.
# Generate your own: python -c "import secrets; print(secrets.token_urlsafe(32))"
EXEC_SERVICE_TOKEN=change-me-generate-a-random-token
# Exec service URL as seen from the control plane. Host-published port for now (M1); becomes the
# internal compose hostname (http://workload:8800) once the control plane is containerized (M3).
EXEC_SERVICE_URL=http://127.0.0.1:8800

# --- Agent budgets / brakes (Milestone 1) ---
AGENT_MAX_ITERATIONS=15
AGENT_MAX_STEPS=25
AGENT_MAX_SECONDS=300
AGENT_KILL_SWITCH=0

# --- Persistence + cache + compaction (Milestone 2) ---
# Sessions persist here so a killed run resumes after restart. SQLite needs zero infra; swap to
# postgresql+asyncpg://... in Phase 9 (one engine for metrics + sessions + pgvector). ADK 2.1 has
# no Redis session service, so Redis (below) backs only the cache/vector, not sessions. NOTE: the
# DatabaseSessionService uses SQLAlchemy's ASYNC engine, so the URL needs an async driver
# (sqlite+aiosqlite, not bare sqlite).
SESSION_DB_URL=sqlite+aiosqlite:///./data/sessions.db

# Redis 8 = the consolidated backbone (semantic cache + vector now). Host-published for now; once
# the control plane is containerized (M3) this becomes redis://redis:6379/0 (the compose hostname).
REDIS_URL=redis://127.0.0.1:6379/0

# Semantic cache: a repeated/similar prompt is served from Redis instead of calling LM Studio.
# The embedding model must be loaded in LM Studio (separate from LMSTUDIO_MODEL — watch VRAM).
# SIMILARITY_THRESHOLD is cosine similarity in [0,1]; 1.0 = identical. 0.97 ≈ "essentially the
# same prompt". Set SEMANTIC_CACHE_ENABLED=0 to disable the cache entirely (model always called).
SEMANTIC_CACHE_ENABLED=1
LMSTUDIO_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5
SEMANTIC_CACHE_SIMILARITY=0.97
SEMANTIC_CACHE_TTL_SECONDS=86400

# Context compaction (small local windows overrun on long loops). The LLM summarizes old events
# every COMPACTION_INTERVAL events, keeping OVERLAP_SIZE for continuity; older raw events are
# replaced by the summary so the context stays bounded.
COMPACTION_INTERVAL=12
COMPACTION_OVERLAP=3

# --- Email / SMTP MCP (Milestone 1.5) ---
# The email MCP server is DISABLED by default in config/mcp_servers.yaml. To let the agent send
# real mail, fill these in and flip `email.enabled: true` in that registry. Send-only (no IMAP).
# For Gmail use an app password, not your account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=change-me-app-password
