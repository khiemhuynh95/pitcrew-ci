# Copy to .env and fill in. NEVER commit a real .env (see .gitignore).
# Env vars grow per phase (HANDOFF §5); this is the Milestone-0 minimum.

# --- LM Studio model endpoint (Milestone 0) ---
# Host-only for now (running `adk web` directly on the host). INVARIANT #4: once the control
# plane is containerized (Milestone 1+), set this to the LM Studio host's LAN IP, NEVER
# localhost — inside a container, localhost is the container itself, not the model host.
LMSTUDIO_API_BASE=http://127.0.0.1:1234/v1

# A strong function-calling instruct model loaded in LM Studio. gemma-4-e4b is multimodal
# (text/image) and reasoning-capable; the whole backbone leans on tool-calling quality.
LMSTUDIO_MODEL=google/gemma-4-e4b

# --- Workload sandbox / exec service (Milestone 1) ---
# Shared bearer token: only the control plane holds it, so only it can drive the exec service.
# Generate your own: python -c "import secrets; print(secrets.token_urlsafe(32))"
EXEC_SERVICE_TOKEN=change-me-generate-a-random-token
# Exec service URL as seen from the control plane. Host-published port for now (M1); becomes the
# internal compose hostname (http://workload:8800) once the control plane is containerized (M3).
EXEC_SERVICE_URL=http://127.0.0.1:8800

# --- Agent budgets / brakes (Milestone 1) ---
AGENT_MAX_ITERATIONS=15
AGENT_MAX_STEPS=25
AGENT_MAX_SECONDS=300
AGENT_KILL_SWITCH=0

# --- Email / SMTP MCP (Milestone 1.5) ---
# The email MCP server is DISABLED by default in config/mcp_servers.yaml. To let the agent send
# real mail, fill these in and flip `email.enabled: true` in that registry. Send-only (no IMAP).
# For Gmail use an app password, not your account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=change-me-app-password
