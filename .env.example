# Copy to .env and fill in. NEVER commit a real .env (see .gitignore).
# Env vars grow per phase (HANDOFF §5); this is the Milestone-0 minimum.

# --- LM Studio model endpoint (Milestone 0) ---
# Host-only for now (running `adk web` directly on the host). INVARIANT #4: once the control
# plane is containerized (Milestone 1+), set this to the LM Studio host's LAN IP, NEVER
# localhost — inside a container, localhost is the container itself, not the model host.
LMSTUDIO_API_BASE=http://127.0.0.1:1234/v1

# A strong function-calling instruct model loaded in LM Studio. gemma-4-e4b is multimodal
# (text/image) and reasoning-capable; the whole backbone leans on tool-calling quality.
LMSTUDIO_MODEL=google/gemma-4-e4b
